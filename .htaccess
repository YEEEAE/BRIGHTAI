# BrightAI .htaccess - Optimized for Google Indexing
# Last updated: 2025-10-01
# Fixed: Redirect issues causing indexing problems

# ============================================
# CORE SETTINGS
# ============================================

# Enable rewrite engine
RewriteEngine On
RewriteBase /

# ============================================
# BRIGHTAI PLATFORM (React App) REWRITES
# ============================================
# 1. Serve static assets directly if they exist in build
RewriteCond %{REQUEST_URI} ^/brightai-platform/(.*)$
RewriteCond %{DOCUMENT_ROOT}/brightai-platform/build/%1 -f
RewriteRule ^brightai-platform/(.*)$ /brightai-platform/build/$1 [L]

# 2. Serve index.html for root of platform
RewriteRule ^brightai-platform/?$ /brightai-platform/build/index.html [L]

# 3. Fallback for SPA routing (any other path in platform -> index.html)
RewriteCond %{REQUEST_URI} ^/brightai-platform/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^brightai-platform/.*$ /brightai-platform/build/index.html [L]

# Set default character set for Arabic content
AddDefaultCharset UTF-8

# Prevent directory browsing
Options -Indexes -MultiViews

# ============================================
# HTTPS & DOMAIN CANONICALIZATION
# ============================================

# Force HTTPS (permanent redirect)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonicalize domain: www to non-www (permanent redirect)
RewriteCond %{HTTP_HOST} ^www\.brightai\.site [NC]
RewriteRule ^(.*)$ https://brightai.site/$1 [L,R=301]

# Handle alternative domain spellings
RewriteCond %{HTTP_HOST} ^(www\.)?brightaii\.com [NC]
RewriteRule ^(.*)$ https://brightai.site/$1 [L,R=301]

# ============================================
# CUSTOM BLOGGER REDIRECTS (LEGACY SLUGS)
# ============================================

Redirect 301 /frontend/pages/blogger/%20production-line.html /frontend/pages/blogger/production-line.html
Redirect 301 /frontend/pages/blogger/astr.doc.html /frontend/pages/blog/index.html
Redirect 301 /frontend/pages/blogger/Generative%20artificial%20intelligence.html /frontend/pages/blogger/Generative-artificial-intelligence.html
Redirect 301 /frontend/pages/blogger/generative-artificial-intelligence-2.html /frontend/pages/blogger/Generative-artificial-intelligence.html
Redirect 301 /frontend/pages/blogger/generative-artificial-intelligence.html /frontend/pages/blogger/Generative-artificial-intelligence.html
Redirect 301 /frontend/pages/blogger/production-line-2.html /frontend/pages/blogger/production-line.html
Redirect 301 /frontend/pages/blogger/%D8%A3%D8%AA%D9%85%D8%AA%D8%A9%20%D8%A7%D9%84%D8%B0%D9%83%D8%A7%D8%A1%20%D8%A7%D9%84%D8%A7%D8%B5%D8%B7%D9%86%D8%A7%D8%B9%D9%8A_%20%D8%AD%D9%84%D9%88%D9%84%20%D9%85%D8%AE%D8%B5%D8%B5%D8%A9%20%D9%84%D8%AA%D8%AD%D9%84%D9%8A%D9%84%20%D8%A7%D9%84%D9%85%D8%B4%D8%A7%D8%B1%D9%8A%D8%B9%20%D9%88%D8%AA%D8%AD%D8%B3%D9%8A%D9%86%20%D9%85%D8%AD%D8%B1%D9%83%D8%A7%D8%AA%20%D8%A7%D9%84%D8%A8%D8%AD%D8%AB%20(1).html /frontend/pages/blogger/ai-transformation.html

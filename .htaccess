RewriteRule ^blog/nca-ai-compliance-saudi(?:\.html)?$ /frontend/pages/blogger/nca-ai-compliance-saudi.html [R=301,L,NE]

RewriteRule ^frontend/pages/blogger/أتمتة-العمليات-باستخدام-الذكاء-الاصطناعي-الطريق-إلى-تحسين-الكفاءة-التشغيلية(?:\.html)?$ /frontend/pages/blogger/process-automation [R=301,L,NE]

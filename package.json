{
  "name": "brightai-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "brightai-platform"
  ],
  "dependencies": {
    "@sentry/react": "^10.38.0",
    "dotenv": "^16.5.0",
    "glob": "^13.0.6",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "aos": "^2.3.4",
    "fast-check": "^3.15.0",
    "gsap": "^3.14.2",
    "jsdom": "^23.0.0",
    "swiper": "^12.1.0",
    "vitest": "^1.0.0"
  },
  "scripts": {
    "build": "npm run performance:budget",
    "dev:frontend": "npm run start --workspace frontend",
    "dev:backend": "npm run start --workspace backend",
    "dev:platform": "npm run start --workspace brightai-platform",
    "test:all": "node scripts/run-monorepo-tests.mjs",
    "test:frontend": "npm run test --workspace frontend",
    "test:backend": "npm run test --workspace backend",
    "test:platform": "npm run test --workspace brightai-platform",
    "performance:budget": "node scripts/check-performance-budget.js",
    "sitemap:all": "node scripts/generate-sitemap-all-pages.mjs",
    "seo:check": "node scripts/seo-ci-check.mjs",
    "seo:html:check": "node scripts/html-seo-governor.mjs",
    "seo:html:fix": "node scripts/html-seo-governor.mjs --fix",
    "resource:audit:before": "node scripts/resource-paths-audit.mjs before",
    "resource:audit:after": "node scripts/resource-paths-audit.mjs after",
    "resource:fix": "node scripts/fix-resource-paths.mjs",
    "deploy:source-of-truth:check": "node scripts/verify-netlify-source-of-truth.mjs",
    "test": "node scripts/run-monorepo-tests.mjs",
    "server": "npm run dev:backend",
    "server:dev": "npm run dev:backend"
  }
}

# BrightAI Platform - Environment Template
# انسخ الملف حسب البيئة:
# - تطوير محلي: .env.local
# - إنتاج: .env.production

# ============================================================
# Core App (Required)
# ============================================================

# مثال صحيح: https://your-project-ref.supabase.co
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co

# anon key من Project Settings > API (مسموح للواجهة)
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# اللغة الافتراضية للتطبيق
REACT_APP_DEFAULT_LOCALE=ar-SA

# المنطقة الزمنية الافتراضية للتقارير والواجهة
REACT_APP_TIMEZONE=Asia/Riyadh

# ============================================================
# API Gateway (Optional)
# ============================================================

# إذا عندك backend/api gateway خارجي، ضع base URL هنا
# مثال: https://api.brightai.sa
REACT_APP_API_BASE_URL=

# ============================================================
# AI / Agent Runtime (Optional)
# ============================================================

# مسار الـ AI proxy في الواجهة (يُفترض يظل /api/ai في الإنتاج)
REACT_APP_AI_PROXY_BASE_URL=/api/ai

# تفعيل/تعطيل الاعتماد على proxy الداخلي في الواجهة
REACT_APP_AI_PROXY_ENABLED=true

# ملاحظة أمنية:
# لا تضع مفاتيح Gemini/Groq داخل REACT_APP_*
# المفاتيح السرية تكون على مستوى الخادم (Netlify Environment Variables).

# أسعار النماذج لكل 1000 token (لأغراض العرض/الحساب فقط)
REACT_APP_GROQ_PRICE_405B=0
REACT_APP_GROQ_PRICE_70B=0
REACT_APP_GROQ_PRICE_8B=0
REACT_APP_GROQ_PRICE_MIXTRAL=0
REACT_APP_GROQ_PRICE_GEMMA2=0

# ============================================================
# AI Secrets (Server-side only: Netlify Function)
# ============================================================

# ضع المفتاح في Netlify كمتغير سري. لا تضع القيمة الحقيقية هنا.
# يتم قبول GROQ_API_KEY حسب سياسة المشروع، و GEMINI_API_KEY كبديل.
GROQ_API_KEY=
GEMINI_API_KEY=

# النموذج الافتراضي في Gemini
GEMINI_MODEL=gemini-flash-latest

# حدود الحماية للتكلفة (Rate Limit)
AI_RATE_LIMIT_PER_MINUTE=30
AI_RATE_LIMIT_WINDOW_MS=60000

# للتطوير فقط: يسمح بدون جلسة مصادقة (لا تفعّله في الإنتاج)
AI_PROXY_ALLOW_UNAUTHENTICATED=false

# ============================================================
# Audit / Logging (Client + Server)
# ============================================================

# تفعيل طبقة التدقيق
AUDIT_LOGGING_ENABLED=true

# endpoint التدقيق من الواجهة
REACT_APP_AUDIT_ENDPOINT=/api/audit

# تفعيل/تعطيل إرسال سجلات التدقيق من الواجهة
REACT_APP_AUDIT_ENABLED=true

# نسبة أخذ العينات من الواجهة (1 = كل الأحداث)
REACT_APP_AUDIT_SAMPLE_RATE=1

# معدل استقبال endpoint التدقيق
AUDIT_RATE_LIMIT_PER_MINUTE=120
AUDIT_RATE_LIMIT_WINDOW_MS=60000

# للتطوير فقط: يسمح بإرسال audit بدون جلسة
AUDIT_ALLOW_UNAUTHENTICATED=false

# الأدوار المسموح لها بعرض جميع السجلات (باقي المستخدمين يرون سجلاتهم فقط)
AUDIT_VIEWER_ROLES=super_admin,company_admin

# fallback مصادقة محلية عند غياب Supabase (موصى به فقط لحالة الطوارئ/البيئات الداخلية)
AUDIT_LOCAL_ADMIN_ENABLED=true
AUDIT_LOCAL_ADMIN_TOKEN=local-admin-access-token
AUDIT_LOCAL_ADMIN_USER_ID=11111111-1111-4111-8111-111111111111

# مفاتيح Supabase الخاصة بوظائف Netlify (server-side)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Netlify Postgres fallback (عادة يتم حقنها تلقائياً في Netlify)
NETLIFY_DATABASE_URL=
NETLIFY_DATABASE_URL_UNPOOLED=

# ============================================================
# External Tools Endpoints (Optional)
# ============================================================

# Endpoint لخدمة البحث في الويب
REACT_APP_TOOL_WEBSEARCH_URL=

# Endpoint لخدمة web scrape
REACT_APP_TOOL_SCRAPE_URL=

# Endpoint لخدمة إرسال البريد
REACT_APP_TOOL_EMAIL_URL=

# Endpoint لخدمة إنشاء مواعيد/تقويم
REACT_APP_TOOL_CALENDAR_URL=

# ============================================================
# Analytics & Monitoring (Optional)
# ============================================================

# القيم المدعومة: ga4 أو none
REACT_APP_ANALYTICS_PROVIDER=none

# GA4 Measurement ID (مثل: G-XXXXXXXXXX)
REACT_APP_ANALYTICS_KEY=

# بديل قديم لـ ANALYTICS_KEY (اختياري للتوافق)
REACT_APP_GA4_ID=

# DSN الخاص بـ Sentry
REACT_APP_SENTRY_DSN=

# نسبة تتبع Sentry من 0 إلى 1
REACT_APP_SENTRY_TRACES_SAMPLE_RATE=0.15

# يفضل ربطه بإصدار Git tag مثل brightai-platform@1.4.2
REACT_APP_RELEASE=brightai-platform@0.1.0

# ============================================================
# Local Admin Mode (Development Only)
# ============================================================

# true لتفعيل تسجيل دخول محلي بدون Supabase (فقط للتطوير)
REACT_APP_ENABLE_LOCAL_ADMIN=false

# بيانات دخول المدير المحلي (لا تستخدمها في الإنتاج)
REACT_APP_LOCAL_ADMIN_EMAIL=admin@brightai.sa
REACT_APP_LOCAL_ADMIN_PASSWORD=change-this-local-password

# token مرئي للواجهة لاستخدام وضع local admin في شاشة /audit-logs
REACT_APP_AUDIT_LOCAL_ADMIN_TOKEN=local-admin-access-token

# ============================================================
# Smoke Flow Test (Optional but Recommended Before Release)
# ============================================================

# مستخدم فعلي داخل Supabase ومربوط بمنظمة
SMOKE_ADMIN_EMAIL=
SMOKE_ADMIN_PASSWORD=

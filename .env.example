# BrightAI Server Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file with real API keys!

# Gemini AI Configuration
GEMINI_API_KEY=GEMINI_KEY_REDACTED
GEMINI_MODEL=gemini-2.5-flash

# Groq AI Configuration
GROQ_API_KEY=YOUR_KEY_HERE
GROQ_MODEL=llama3-70b-8192
GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo
GROQ_STREAM_TIMEOUT_MS=30000

# RAG Search Configuration (optional)
RAG_INDEX_REFRESH_MS=600000
RAG_MAX_FILES=180
RAG_MAX_FILE_BYTES=512000
RAG_CHUNK_SIZE_CHARS=900
RAG_CHUNK_OVERLAP_CHARS=180
RAG_MIN_CHUNK_CHARS=130

# Server Configuration (optional)
PORT=3000
NODE_ENV=development
MAX_UPLOAD_BODY_BYTES=41943040

# GA4 Measurement Protocol (optional - required for server-side conversion events)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
# Optional shared key to protect analytics webhook endpoint
ANALYTICS_WEBHOOK_KEY=
# Set to 1 to use GA4 debug endpoint and receive validation messages
GA4_MP_DEBUG=0

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS_PER_MINUTE=30
# Storage type for rate limiting: 'memory' (default) or 'redis'
# Use 'redis' for persistent rate limiting across server restarts
RATE_LIMIT_STORAGE=memory

# Session Privacy Controls (optional)
CHAT_SESSION_TTL_MS=600000
CHAT_SESSION_MAX_ITEMS=8
CHAT_SESSION_MAX_CHARS=600

# BrightAI - متغيرات البيئة (قالب)

# انسخ هذا الملف إلى .env وأضف مفاتيحك الحقيقية

# ⚠️ لا ترفع ملف .env إلى Git أبداً!

# === Gemini AI (الرئيسي - مطلوب) ===

GEMINI_API_KEY=YOUR_SECRET_HERE

GEMINI_MODEL=gemini-2.5-flash

# === إعدادات الخادم ===

NODE_ENV=production

PORT=3000

RATE_LIMIT_REQUESTS_PER_MINUTE=30

# === إعدادات الجلسة ===

CHAT_SESSION_TTL_MS=600000

CHAT_SESSION_MAX_ITEMS=8

# === API Gateway (اختياري) ===
# اتركه فارغاً لاستخدام same-origin (Netlify)
# أو عيّنه لـ backend منفصل مثل: https://api.brightai.sa

BRIGHTAI_API_BASE=
